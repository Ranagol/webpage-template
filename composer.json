{
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "System\\": "system/",
            "Database\\": "database/",
            "Domain\\": "domain/"
        },
        "classmap": [
            "tests"
        ]
	},
    "require": {
        "vlucas/phpdotenv": "^5.3",
        "illuminate/database": "^8.51",
        "bramus/router": "~1.5",
        "symfony/console": "^5.4",
        "nesbot/carbon": "^2.72",
        "jenssegers/blade": "^1.4"
    },
    "scripts": {
        "migrate": "@php database/migrations/createTablesInDatabase.php",
		"seed": "@php database/seeders/seedDatabase.php",
        "cs-fixer": "php-cs-fixer fix --config=.php-cs-fixer.php",
        "phpstan": "php -d memory_limit=1G ./vendor/bin/phpstan analyse",
        "phpunit": "php -d error_reporting=\"E_ALL & ~E_DEPRECATED & ~E_USER_DEPRECATED\" ./vendor/bin/phpunit",
        "full-check": [
            "@cs-fixer",
            "@phpstan",
            "@phpunit"
        ],
        "enter-docker": "docker-compose exec -it php bash",
        "trains": "cat domain/Trains/taskDataOriginal | php console.php trains",
        "rebuild-docker": "docker-compose up --build --force-recreate"
	},
    "scripts-descriptions": {
        "migrate": "This should start the migration, and create tables in the db. Just write 'composer migrate'.",
        "seed": "This should seed the database with some data. Just write 'composer seed'."
    },
    "require-dev": {
        "phpunit/phpunit": "^11.4",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94"
    }
    ,
    "config": {
        "platform": {
            "php": "8.1.0"
        }
    }
}
