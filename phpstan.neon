parameters:
    level: 6

    # Analyze the actual source directories by default
    paths:
        - app
        - bootstrap
        - database
        - resources
        - routes
        - system
        - tests
        - domain

    # Avoid analyzing generated/cache artifacts that cause noise and memory bloat
    excludePaths:
        analyse:
            - cache/*
            - public/cache/*
            - storage/*
            - vendor/*
            - docker

    # Keep worker count modest to reduce per-run memory spikes
    parallel:
        maximumNumberOfProcesses: 2

    # Reduce docblock strictness
    treatPhpDocTypesAsCertain: false

    # Don't report unmatched ignored errors
    reportUnmatchedIgnoredErrors: false

    ignoreErrors:

        # Stop complaining about missing iterable generics
        - '#missingType\.iterableValue#'
